# Openmork per-instance config (portable)
# Copy to e.g. /etc/openmork/instances/dev-a.env or ./ops/openmork/instances/dev-a.env

INSTANCE_NAME=dev-a

# Base directories for this instance
OPENMORK_HOME=/opt/openmork/instances/dev-a
OPENMORK_REPO=/opt/openmork/openmork
OPENMORK_ENV_FILE=/opt/openmork/instances/dev-a/.env

# Scoped runtime files (must be unique per instance)
PID_FILE=/opt/openmork/instances/dev-a/run/openmork.pid
LOG_FILE=/opt/openmork/instances/dev-a/log/openmork.log
INSTANCE_LOCK_FILE=/opt/openmork/instances/dev-a/run/restart.lock

# Model/runtime knobs
MODEL=gpt-5.3-codex
OPENMORK_BIN=/opt/openmork/openmork
# Optional explicit command override:
# OPENMORK_START_CMD="python3 run_agent.py"

# Optional health HTTP endpoint for health_instance.sh
# HEALTH_URL=http://127.0.0.1:8787/health

# Optional waits
STARTUP_WAIT_SECONDS=20
STOP_WAIT_SECONDS=20
